{
  "manifest_version": 3,
  "name": "Elevator — Background Music for Shared Tabs",
  "version": "1.0.0",
  "description": "Play background music inside any tab so it is captured when you share that tab's audio in Meet/Zoom/Discord.",
  "permissions": ["scripting", "activeTab", "storage", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Elevator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
